{
  "id": "base-default-code-review-graph",
  "description": "Your base skills plus mostly out-of-box code-review-graph MCP, with upstream CRG skills, AGENTS instructions, and a fresh code-review graph generated via uvx in each run worktree before Codex starts. The project-scoped Codex MCP config omits --tools so CRG exposes its default tool set.",
  "materialize": {
    "copy": [
      {
        "from": "execution/base-skills",
        "to": ".agents/skills"
      },
      {
        "from": "execution/skills/code-review-graph",
        "to": ".agents/skills/code-review-graph"
      },
      {
        "from": "execution/skills/review-changes",
        "to": ".agents/skills/review-changes"
      },
      {
        "from": "execution/skills/refactor-safely",
        "to": ".agents/skills/refactor-safely"
      },
      {
        "from": "execution/skills/explore-codebase",
        "to": ".agents/skills/explore-codebase"
      },
      {
        "from": "execution/skills/debug-issue",
        "to": ".agents/skills/debug-issue"
      },
      {
        "from": "execution/configs/code-review-graph",
        "to": ".agents/configs/code-review-graph"
      },
      {
        "from": "execution/scripts/write-code-review-graph-codex-config.py",
        "to": ".agents/scripts/write-code-review-graph-codex-config.py"
      },
      {
        "from": "execution/scripts/append-code-review-graph-agents.py",
        "to": ".agents/scripts/append-code-review-graph-agents.py"
      }
    ]
  },
  "pre_agent": {
    "setup_scope": "per-run",
    "commands": [
      {
        "id": "code-review-graph-version",
        "argv": [
          "uvx",
          "code-review-graph",
          "--version"
        ],
        "cwd": ".",
        "timeout_seconds": 120,
        "required": true
      },
      {
        "id": "code-review-graph-agents-instructions",
        "argv": [
          "python3",
          ".agents/scripts/append-code-review-graph-agents.py",
          "--repo-root",
          "."
        ],
        "cwd": ".",
        "timeout_seconds": 60,
        "required": true
      },
      {
        "id": "code-review-graph-codex-config",
        "argv": [
          "python3",
          ".agents/scripts/write-code-review-graph-codex-config.py",
          "--repo-root",
          ".",
          "--launcher",
          "uvx"
        ],
        "cwd": ".",
        "timeout_seconds": 60,
        "required": true
      },
      {
        "id": "code-review-graph-build",
        "argv": [
          "uvx",
          "code-review-graph",
          "build",
          "--repo",
          "."
        ],
        "cwd": ".",
        "timeout_seconds": 1200,
        "required": true
      },
      {
        "id": "code-review-graph-status",
        "argv": [
          "uvx",
          "code-review-graph",
          "status",
          "--repo",
          "."
        ],
        "cwd": ".",
        "timeout_seconds": 180,
        "required": true
      }
    ]
  },
  "expectations": {
    "should_verify_with_source": true
  },
  "_path": "/home/simon/repos/lorq/code/lorq/modes/base-default-code-review-graph.yaml"
}
