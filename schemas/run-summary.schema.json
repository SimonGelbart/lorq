{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-eval.local/schemas/run-summary.schema.json",
  "title": "Run summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_status",
    "mode",
    "case",
    "prompt_style",
    "repetition"
  ],
  "properties": {
    "schema_version": {
      "const": "agent-eval.result.v1"
    },
    "contract_version": {
      "const": "agent-eval.contract.v1"
    },
    "run_status": {
      "enum": [
        "completed",
        "setup_failed",
        "agent_failed",
        "validation_failed",
        "judge_failed"
      ]
    },
    "repo": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "case": {
      "type": "string"
    },
    "prompt_style": {
      "type": "string"
    },
    "repetition": {
      "type": "integer"
    },
    "run_dir": {
      "type": "string"
    },
    "worktree": {
      "type": "string"
    },
    "setup": {
      "type": "object"
    },
    "agent_summary": {
      "type": "object"
    },
    "validation": {
      "type": "object"
    }
  }
}
