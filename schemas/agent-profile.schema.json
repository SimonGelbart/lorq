{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-eval.local/schemas/agent-profile.schema.json",
  "title": "Agent profile",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "backend": {
      "enum": [
        "codex",
        "codex-cli",
        "copilot",
        "copilot-cli",
        "copilot-sdk",
        "generic",
        "deterministic-fake"
      ]
    },
    "command": {
      "type": "string"
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input_mode": {
      "enum": [
        "stdin",
        "argument"
      ]
    },
    "output_format": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "model": {
      "type": "string"
    },
    "reasoning_effort": {
      "type": "string"
    },
    "permission_policy": {
      "type": "string"
    },
    "isolate_home": {
      "type": "boolean",
      "description": "Run the agent with per-run HOME pointing at a generated runtime-home directory."
    },
    "isolated_home": {
      "type": "boolean",
      "description": "Alias for isolate_home."
    },
    "isolate_codex_home": {
      "type": "boolean",
      "description": "Run Codex CLI with per-run CODEX_HOME under the runtime-home directory."
    },
    "isolated_codex_home": {
      "type": "boolean",
      "description": "Alias for isolate_codex_home."
    },
    "fixture_file": {
      "type": "string",
      "description": "YAML/JSON deterministic fake agent fixture, relative to suite root when loaded by the CLI."
    },
    "scenario_file": {
      "type": "string",
      "description": "Alias for fixture_file for deterministic fake agent profiles."
    }
  }
}
